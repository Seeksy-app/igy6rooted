# Server Configuration
NODE_ENV=production
PORT=3001

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/igy6_rooted

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=https://your-frontend-domain.com

# Jobber OAuth
JOBBER_CLIENT_ID=your-jobber-client-id
JOBBER_CLIENT_SECRET=your-jobber-client-secret
JOBBER_REDIRECT_URI=https://your-backend-domain.com/api/oauth/jobber/callback

# Google Ads OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_ADS_DEVELOPER_TOKEN=your-google-ads-developer-token

# Meta Ads OAuth
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret

# ElevenLabs
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_AGENT_ID=your-elevenlabs-agent-id
ELEVENLABS_HMAC_SECRET=your-hmac-secret

# Mapbox
MAPBOX_PUBLIC_TOKEN=your-mapbox-token

# Firecrawl
FIRECRAWL_API_KEY=your-firecrawl-api-key

# Logging
LOG_LEVEL=info
